{
  "name": "knex-firebird-adapter",
  "version": "1.0.1",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "babel src --out-dir lib && cp src/index.d.ts lib/index.d.ts",
    "test": "jest --detectOpenHandles --forceExit --runInBand",
    "prepublishOnly": "npm run build",
    "lint": "eslint --fix \"{src,tests}/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\"",
    "changelog": "npx gitmoji-changelog",
    "release": "npm run version",
    "version": "npm run changelog && code --wait CHANGELOG.md && git add README.md CHANGELOG.md"
  },
  "keywords": [
    "node",
    "firebird",
    "sql",
    "knex",
    "orm"
  ],
  "author": "Martin Köditz <martin.koeditz@syndesk-sw.de>",
  "license": "MIT",
  "homepage": "https://github.com/MartinKoeditz/knex-firebird-adapter#readme",
  "description": "Firebird adapter for Knex.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MartinKoeditz/knex-firebird-adapter.git"
  },
  "bugs": {
    "url": "https://github.com/MartinKoeditz/knex-firebird-adapter/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.2",
    "lodash": "^4.17.21",
    "node-firebird-driver-native": "^3.1.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.0",
    "@babel/core": "^7.23.2",
    "@babel/eslint-parser": "^7.27.0",
    "@babel/plugin-transform-modules-commonjs": "^7.23.0",
    "@babel/plugin-transform-runtime": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-jest": "^29.0.1",
    "husky": "9.1.7",
    "jest": "^30.0.1",
    "jest-circus": "^30.2.0",
    "knex": "^3.0.1",
    "node-firebird-driver-native": "^3.2.2",
    "prettier": "^2.6.2"
  },
  "peerDependencies": {
    "knex": ">=0.95.15"
  },
  "resolutions": {
    "set-value": ">=4.0.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint && npm run format"
    }
  },
  "files": [
    "lib"
  ]
}
